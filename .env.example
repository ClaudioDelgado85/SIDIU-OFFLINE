# Configuración del Servidor
PORT=3000
NODE_ENV=development

# ============================================
# Estrategia de Base de Datos (sqlite | mysql)
# ============================================
# SQLite es el modo por defecto. No es necesario
# definir DB_CLIENT para que funcione offline.
DB_CLIENT=sqlite
SQLITE_DB_PATH=./database/gestion_municipal.db

# ============================================
# Configuración MySQL (Nube - TiDB/Render)
# Para restaurar MySQL: cambiar DB_CLIENT=mysql
# y descomentar las líneas siguientes.
# ============================================
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=gestion_municipal
# DB_PORT=3306
# DB_SSL=false

# Configuración JWT (Autenticación)
JWT_SECRET=tu_clave_secreta_muy_segura_cambiala_en_produccion_12345
JWT_EXPIRES_IN=24h

# Configuración CORS (LAN municipal)
CORS_ORIGIN=*
